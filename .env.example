# ─────────────────────────────────────────────────────────────
# BuildIMS — Environment Configuration
# Copy this file to .env (root) and backend/.env, then fill in values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────

NODE_ENV=development

# ── Database ───────────────────────────────────────────────────
# Local (no Docker): DB_HOST=127.0.0.1
# Docker:            DB_HOST=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=buildims
DB_USER=buildims
DB_PASSWORD=your_db_password

# ── Redis ──────────────────────────────────────────────────────
# Local (no Docker): REDIS_HOST=127.0.0.1
# Docker:            REDIS_HOST=redis
# Memurai (Windows) runs without password — leave REDIS_PASSWORD blank
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT (generate with: openssl rand -base64 64) ───────────────
JWT_SECRET=generate_with_openssl_rand_base64_64
JWT_REFRESH_SECRET=generate_with_openssl_rand_base64_64
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Email (SendGrid) ───────────────────────────────────────────
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=your_verified_sender@example.com

# ── Frontend URL (for email links) ─────────────────────────────
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:4000/api
VITE_WS_URL=ws://localhost:4000

# ── AWS S3 (optional) ──────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_S3_BUCKET=buildims-uploads
AWS_REGION=ap-south-1

# ── Anthropic Claude API ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── GitHub API ─────────────────────────────────────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── JSearch (RapidAPI) ─────────────────────────────────────────
JSEARCH_API_KEY=your_jsearch_rapidapi_key

# ── Hugging Face ───────────────────────────────────────────────
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
